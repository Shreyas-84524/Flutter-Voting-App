rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Checks if the user is logged into Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Safely fetches the current logged-in voter's document data
    function getVoterData() {
      return get(/databases/$(database)/documents/voters/$(request.auth.uid)).data;
    }

    // Helper: Verifies that the current request time is before the election deadline
    function isVotingOpen() {
      return request.time < get(/databases/$(database)/documents/system_config/election_state).data.endTime;
    }

    match /system_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /voters/{voterId} {
      allow read: if true;
      // Allow the user to update their own document, but ONLY if they are changing hasVoted to true and election is open
      allow update: if isAuthenticated() 
                    && request.auth.uid == voterId 
                    && resource.data.hasVoted == false 
                    && request.resource.data.hasVoted == true
                    && isVotingOpen();
    }

    match /constituencies/{constituencyId} {
      allow read: if true;
      allow write: if false;
      
      match /candidates/{candidateId} {
        allow read: if true;
        // Allow updating vote counts only if incremented by exactly 1, the voter hasn't already voted, and election is open
        allow update: if isAuthenticated()
                      && request.resource.data.votes == resource.data.votes + 1
                      && getVoterData().hasVoted == false
                      && isVotingOpen();
      }
    }

    // 🔒 Immutable Audit Log Security Rules
    match /votes/{voteId} {
      // Allow read so the public dashboard can count the votes and calculate turnout
      allow read: if true;
      // Users can only submit a ballot if they are logged in, signing it with their own UID, and election is open
      allow create: if isAuthenticated() 
                    && request.resource.data.voterId == request.auth.uid
                    && getVoterData().hasVoted == false
                    && isVotingOpen();
      // Completely block modification or deletion to ensure zero election tampering
      allow update, delete: if false;
    }
  }
}
